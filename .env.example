# Copy this file to `.env` for local development. Never commit a real `.env`.

# Local dev: matches the `postgres` service in docker-compose.yml.
# Production (Neon): use a pooled connection string, not a direct one — see
# docs/architecture.md's Postgres section and docs/adr/0001-hosting-and-backend-runtime.md.
DATABASE_URL="postgresql://soccerdads:soccerdads@localhost:5432/soccerdads?schema=public"

# Only needed in production if using Prisma Accelerate for pooling (the ADR's
# default choice). Leave unset for local dev against docker-compose postgres.
# PRISMA_ACCELERATE_URL="prisma://accelerate.prisma-data.net/?api_key=__YOUR_API_KEY__"
